# Precura - copy this file to .env.local and fill in real values
# .env.local is gitignored and will never be committed

# Supabase (from supabase.com/dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (for /api/discuss AI chat)
ANTHROPIC_API_KEY=your-anthropic-key

# Allowed emails (comma-separated, enforced by middleware on /member/*)
ALLOWED_EMAILS=eoghan@vestego.com,tomas@example.com
